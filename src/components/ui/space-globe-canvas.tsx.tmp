import React, { useEffect, useRef } from "react";
import * as THREE from "three";

interface CityData {
  name: string;
  lat: number;
  lon: number;
}

export const SpaceGlobeCanvas: React.FC = () => {
  const containerRef = useRef<HTMLDivElement | null>(null);

  useEffect(() => {
    const container = containerRef.current;
    if (!container) return;

    let width = container.clientWidth;
    let height = container.clientHeight;

    // Create Scene, Camera, Renderer
    const scene = new THREE.Scene();
    
    // Perspective Camera for deep volumetric space depth
    const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
    camera.position.z = 12; // Start far away

    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: "high-performance" });
    renderer.setSize(width, height);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    container.appendChild(renderer.domElement);

    // Group to hold all globe elements for easy rotation/scaling
    const globeGroup = new THREE.Group();
    scene.add(globeGroup);

    // 1. Warm sunlight (sunlit side) and cool rim fill (shadow side)
    const ambientLight = new THREE.AmbientLight(0x0a102d, 1.2); // Faint cosmic blue fill
    scene.add(ambientLight);

    const sunLight = new THREE.DirectionalLight(0xfff5e6, 2.5); // Warm sun light
    sunLight.position.set(5, 3, 5);
    scene.add(sunLight);

    const rimLight = new THREE.DirectionalLight(0x38bdf8, 1.8); // Electric blue atmosphere rim
    rimLight.position.set(-5, -2, -5);
    scene.add(rimLight);

    // 2. Load Local High-Res Textures
    const textureLoader = new THREE.TextureLoader();
    const earthMap = textureLoader.load("/earth_map.jpg");
    const earthSpecular = textureLoader.load("/earth_specular.jpg");
    const earthNormal = textureLoader.load("/earth_normal.jpg");
    const earthClouds = textureLoader.load("/earth_clouds.png");

    // Setup Earth Sphere
    const globeRadius = 1.8;
    const earthGeometry = new THREE.SphereGeometry(globeRadius, 64, 64);
    
    // MeshPhongMaterial behaves ideally with Earth specular maps
    const earthMaterial = new THREE.MeshPhongMaterial({
      map: earthMap,
      specularMap: earthSpecular,
      specular: new THREE.Color(0x353535),
      shininess: 25,
      normalMap: earthNormal,
      normalScale: new THREE.Vector2(1.1, 1.1),
    });

    const earthMesh = new THREE.Mesh(earthGeometry, earthMaterial);
    globeGroup.add(earthMesh);

    // 3. Clouds Overlay (slightly larger sphere)
    const cloudGeometry = new THREE.SphereGeometry(globeRadius + 0.025, 64, 64);
    const cloudMaterial = new THREE.MeshPhongMaterial({
      map: earthClouds,
      transparent: true,
      opacity: 0.4,
      blending: THREE.NormalBlending,
      side: THREE.DoubleSide,
    });
    const cloudsMesh = new THREE.Mesh(cloudGeometry, cloudMaterial);
    globeGroup.add(cloudsMesh);

    // 4. Volumetric Atmosphere Glow (custom shader for Fresnel refraction glow)
    const atmosphereGeometry = new THREE.SphereGeometry(globeRadius + 0.15, 64, 64);
    const atmosphereMaterial = new THREE.ShaderMaterial({
      vertexShader: `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
          vViewPosition = -mvPosition.xyz;
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vec3 normal = normalize(vNormal);
          float intensity = pow(0.72 - dot(normal, vec3(0.0, 0.0, 1.0)), 2.6);
          gl_FragColor = vec4(0.22, 0.58, 1.0, 1.0) * intensity;
        }
      `,
      blending: THREE.AdditiveBlending,
      side: THREE.BackSide,
      transparent: true,
    });
    const atmosphereMesh = new THREE.Mesh(atmosphereGeometry, atmosphereMaterial);
    globeGroup.add(atmosphereMesh);

    // 5. Starfield Background
    const starGeometry = new THREE.BufferGeometry();
    const starCount = 1800;
    const starPositions = new Float32Array(starCount * 3);
    for (let i = 0; i < starCount * 3; i += 3) {
      const radius = 180 + Math.random() * 150;
      const u = Math.random();
      const v = Math.random();
      const theta = u * 2.0 * Math.PI;
      const phi = Math.acos(2.0 * v - 1.0);
      starPositions[i] = radius * Math.sin(phi) * Math.cos(theta);
      starPositions[i + 1] = radius * Math.sin(phi) * Math.sin(theta);
      starPositions[i + 2] = radius * Math.cos(phi);
    }
    starGeometry.setAttribute("position", new THREE.BufferAttribute(starPositions, 3));
    const starMaterial = new THREE.PointsMaterial({
      color: 0xffffff,
      size: 0.6,
      transparent: true,
      opacity: 0.8,
    });
    const starfield = new THREE.Points(starGeometry, starMaterial);
    scene.add(starfield);

    // 6. Holographic Grid Lines representing global telemetry
    const gridGroup = new THREE.Group();
    globeGroup.add(gridGroup);
    
    for (let i = 0; i < 3; i++) {
      const torusGeo = new THREE.TorusGeometry(3.2 + i * 0.6, 0.003, 8, 64);
      const torusMat = new THREE.MeshBasicMaterial({
        color: 0x2563eb,
        transparent: true,
        opacity: 0.04,
        blending: THREE.AdditiveBlending
      });
      const torusMesh = new THREE.Mesh(torusGeo, torusMat);
      torusMesh.rotation.x = Math.random() * Math.PI;
      torusMesh.rotation.y = Math.random() * Math.PI;
      gridGroup.add(torusMesh);
    }

    // 7. Network Nodes (Cali origin -> target markets)
    const cities: CityData[] = [
      { name: "Cali (HUB)", lat: 3.4516, lon: -76.5320 },
      { name: "Bogotá", lat: 4.7110, lon: -74.0721 },
      { name: "Medellín", lat: 6.2518, lon: -75.5636 },
      { name: "Miami", lat: 25.7617, lon: -80.1918 },
      { name: "São Paulo", lat: -23.5505, lon: -46.6333 },
      { name: "Lima", lat: -12.0464, lon: -77.0428 },
      { name: "Ciudad de México", lat: 19.4326, lon: -99.1332 },
      { name: "Santiago", lat: -33.4489, lon: -70.6693 },
      { name: "Madrid", lat: 40.4168, lon: -3.7038 },
      { name: "Tokio", lat: 35.6762, lon: 139.6503 },
    ];

    const latLonToVector3 = (lat: number, lon: number, r: number): THREE.Vector3 => {
      const phi = (90 - lat) * (Math.PI / 180);
      const theta = (lon + 180) * (Math.PI / 180);
      return new THREE.Vector3(
        -r * Math.sin(phi) * Math.sin(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.cos(theta)
      );
    };

    const nodePositions = cities.map((c) => latLonToVector3(c.lat, c.lon, globeRadius));
    const caliPos = nodePositions[0];

    // Cali (HUB) node is a violet glow, other nodes are electric cyan
    const nodeGeometry = new THREE.SphereGeometry(0.038, 16, 16);
    const caliGeometry = new THREE.SphereGeometry(0.065, 16, 16);
    
    nodePositions.forEach((pos, idx) => {
      const isCali = idx === 0;
      const nodeMat = new THREE.MeshBasicMaterial({
        color: isCali ? 0x7c3aed : 0x38bdf8,
        toneMapped: false,
      });
      const nodeMesh = new THREE.Mesh(isCali ? caliGeometry : nodeGeometry, nodeMat);
      nodeMesh.position.copy(pos);
      globeGroup.add(nodeMesh);
    });

    // 8. Pulsing Electromagnetic NFC rings tangent to Cali
    const ringsGroup = new THREE.Group();
    globeGroup.add(ringsGroup);

    const ringCount = 3;
    const rings: { mesh: THREE.Mesh; scale: number; speed: number }[] = [];
    
    for (let i = 0; i < ringCount; i++) {
      const ringGeo = new THREE.RingGeometry(0.03, 0.032 + 0.006 * i, 32);
      const ringMat = new THREE.MeshBasicMaterial({
        color: 0x7c3aed, // Violet
        transparent: true,
        opacity: 0.85,
        side: THREE.DoubleSide,
        blending: THREE.AdditiveBlending
      });
      const ringMesh = new THREE.Mesh(ringGeo, ringMat);
      ringMesh.position.copy(caliPos.clone().multiplyScalar(1.004));
      ringMesh.lookAt(caliPos.clone().multiplyScalar(2.0));
      ringsGroup.add(ringMesh);
      
      rings.push({
        mesh: ringMesh,
        scale: 1.0,
        speed: 1.0 + i * 0.35,
      });
    }

    // 9. Curved data connections and moving light pulses
    const connectionCurves: THREE.QuadraticBezierCurve3[] = [];
    const connectionLines: THREE.Line[] = [];
    const pulseParticles: { mesh: THREE.Mesh; curve: THREE.QuadraticBezierCurve3; offset: number }[] = [];

    const pulseGeometry = new THREE.SphereGeometry(0.022, 8, 8);
    const pulseMaterial = new THREE.MeshBasicMaterial({
      color: 0x38bdf8,
      transparent: true,
      opacity: 0.9,
      blending: THREE.AdditiveBlending,
    });

    cities.slice(1).forEach((_, idx) => {
      const destPos = nodePositions[idx + 1];
      
      const midPoint = new THREE.Vector3().addVectors(caliPos, destPos).multiplyScalar(0.5);
      const dist = caliPos.distanceTo(destPos);
      const arcHeight = globeRadius + dist * 0.38;
      const controlPoint = midPoint.clone().normalize().multiplyScalar(arcHeight);

      const curve = new THREE.QuadraticBezierCurve3(caliPos, controlPoint, destPos);
      connectionCurves.push(curve);

      // Curved line mesh
      const points = curve.getPoints(40);
      const lineGeom = new THREE.BufferGeometry().setFromPoints(points);
      const lineMat = new THREE.LineBasicMaterial({
        color: 0x38bdf8,
        transparent: true,
        opacity: 0.1,
      });
      const lineMesh = new THREE.Line(lineGeom, lineMat);
      globeGroup.add(lineMesh);
      connectionLines.push(lineMesh);

      // Create 2 cascading light beams along each curve
      for (let p = 0; p < 2; p++) {
        const pulseMesh = new THREE.Mesh(pulseGeometry, pulseMaterial.clone());
        pulseMesh.visible = false;
        globeGroup.add(pulseMesh);

        pulseParticles.push({
          mesh: pulseMesh,
          curve,
          offset: idx * 0.12 + p * 0.5,
        });
      }
    });

    // 10. Scroll-driven orchestration (continuous, hero-first)

    // Mouse tilt parallax movement
    let mouseX = 0, mouseY = 0;
    let targetMouseX = 0, targetMouseY = 0;

    const onMouseMove = (e: MouseEvent) => {
      targetMouseX = (e.clientX / window.innerWidth) * 2 - 1;
      targetMouseY = -(e.clientY / window.innerHeight) * 2 + 1;
    };
    window.addEventListener("mousemove", onMouseMove);

    // Resize Handler
    const handleResize = () => {
      if (!container) return;
      width = container.clientWidth;
      height = container.clientHeight;
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height);
    };
    window.addEventListener("resize", handleResize);

    // Render Animation Loop
    let baseTime = 0;
    let currentX = 0;
    let currentY = 0;
    let currentZ = 12.0;
    let currentScale = 0.2;
    let currentOpacity = 0.0;
    let currentConnectionIntensity = 0.0;

    const animate = () => {
      baseTime += 0.007;

      const vh = window.innerHeight;
      const isMobile = width < 768;

      // Continuous scroll progress measured in "viewports scrolled".
      const p = window.scrollY / vh;
      const t1 = Math.min(Math.max(p, 0), 1);           // hero -> backdrop across first viewport
      const t2 = Math.min(Math.max((p - 1) / 2, 0), 1); // slow drift deeper in the page
      const tConn = Math.min(Math.max(p / 0.65, 0), 1); // light network warms up during the hero

      // Hero: the globe is the star — larger and offset to the right on desktop,
      // centered on mobile. As the user scrolls it eases back into a living
      // backdrop (dimmer, further away) so the content stays perfectly legible.
      const targetX = isMobile ? 0 : THREE.MathUtils.lerp(1.9, 0.35, t1);
      const targetY = THREE.MathUtils.lerp(0.15, -0.25, t1);
      const targetZ = THREE.MathUtils.lerp(5.5, 7.6, t1);
      const targetScale = 1.0;
      const targetOpacity = isMobile
        ? THREE.MathUtils.lerp(0.5, 0.24, t1)
        : THREE.MathUtils.lerp(1.0, 0.4, t1);
      const targetConnectionIntensity = THREE.MathUtils.lerp(0.35, 1.0, tConn);
      const targetGlobeRotX = 0.35 - t2 * 0.12;
      const targetGlobeRotY = baseTime * 0.05 + p * 0.22;

      // Smoothly interpolate current state with inertia
      currentX = THREE.MathUtils.lerp(currentX, targetX, 0.05);
      currentY = THREE.MathUtils.lerp(currentY, targetY, 0.05);
      currentZ = THREE.MathUtils.lerp(currentZ, targetZ, 0.05);
      currentScale = THREE.MathUtils.lerp(currentScale, targetScale, 0.05);
      currentOpacity = THREE.MathUtils.lerp(currentOpacity, targetOpacity, 0.08);
      currentConnectionIntensity = THREE.MathUtils.lerp(currentConnectionIntensity, targetConnectionIntensity, 0.05);

      // Apply values to meshes
      globeGroup.position.x = currentX;
      globeGroup.position.y = currentY;
      globeGroup.scale.setScalar(currentScale);
      
      // Update DOM container opacity directly for performance (bypassing React)
      if (container) {
        container.style.opacity = currentOpacity.toFixed(3);
      }

      // Interpolate mouse movement parallax
      mouseX += (targetMouseX - mouseX) * 0.04;
      mouseY += (targetMouseY - mouseY) * 0.04;

      camera.position.x = THREE.MathUtils.lerp(camera.position.x, mouseX * 0.4, 0.05);
      camera.position.y = THREE.MathUtils.lerp(camera.position.y, mouseY * 0.4, 0.05);
      camera.position.z = currentZ;
      camera.lookAt(new THREE.Vector3(currentX, currentY, 0));

      // Earth rotation and tilt
      earthMesh.rotation.y = baseTime * 0.08 + targetGlobeRotY;
      cloudsMesh.rotation.y = baseTime * 0.12 + targetGlobeRotY * 1.25; // Clouds drift faster
      
      globeGroup.rotation.x = THREE.MathUtils.lerp(globeGroup.rotation.x, targetGlobeRotX, 0.05);
      globeGroup.rotation.z = baseTime * 0.01;

      // Faint coordinate grid revolve
      gridGroup.rotation.y = -baseTime * 0.015;
      gridGroup.rotation.x = baseTime * 0.008;

      // Animate Cali electromagnetism ripples
      rings.forEach((ring) => {
        const scaleVal = 1.0 + ((baseTime * ring.speed) % 2.5);
        ring.mesh.scale.setScalar(scaleVal);
        const ringMat = ring.mesh.material as THREE.MeshBasicMaterial;
        ringMat.opacity = Math.max(0, 1.0 - (scaleVal / 3.0)) * currentConnectionIntensity;
      });

      // Animate connections (pulse particles) along routes
      pulseParticles.forEach((pulse, idx) => {
        const lineMat = connectionLines[Math.floor(idx / 2)].material as THREE.LineBasicMaterial;
        lineMat.opacity = THREE.MathUtils.lerp(lineMat.opacity, 0.05 + 0.3 * currentConnectionIntensity, 0.05);

        if (currentConnectionIntensity > 0.05) {
          pulse.mesh.visible = true;
          // speed up particles as connections light up
          const t = (baseTime * (0.55 + currentConnectionIntensity * 0.25) + pulse.offset) % 1.0;
          const pos = pulse.curve.getPointAt(t);
          pulse.mesh.position.copy(pos);
          
          const pulseScale = (1.0 + Math.sin(baseTime * 18 + idx) * 0.3) * currentConnectionIntensity;
          pulse.mesh.scale.setScalar(pulseScale);
        } else {
          pulse.mesh.visible = false;
        }
      });

      // Starfield revolve
      starfield.rotation.y = baseTime * 0.015;

      renderer.render(scene, camera);
      requestAnimationFrame(animate);
    };

    animate();

    // Cleanup
    return () => {
      window.removeEventListener("mousemove", onMouseMove);
      window.removeEventListener("resize", handleResize);
      renderer.dispose();
      if (container.contains(renderer.domElement)) {
        container.removeChild(renderer.domElement);
      }
    };
  }, []);

  return (
    <div
      ref={containerRef}
      style={{ opacity: 0 }}
      className="fixed inset-0 w-full h-full -z-10 pointer-events-none bg-[#070A12] transition-opacity duration-500 ease-out"
    />
  );
};
